##############################################################################
#  PatchMaster -- Environment Configuration
#  Copy this file to .env and edit before running install.sh
##############################################################################

# ── Networking ──
# IP or hostname that agents and browsers use to reach this server.
# Auto-detected during install if left blank.
SERVER_IP=

# Service ports (change if defaults conflict)
FRONTEND_PORT=3000
BACKEND_PORT=8000
# GRAFANA_PORT=3001        # Also available in monitoring section below
# PROMETHEUS_PORT=9090      # Also available in monitoring section below

# ── Database ──
POSTGRES_USER=patchmaster
POSTGRES_PASSWORD=patchmaster
POSTGRES_DB=patchmaster

# ── Security ──
# CHANGE THIS to a random 32+ character string in production!
# Pre-generated convenience value; override for production deployments.
JWT_SECRET=5e91c5c9d0b5494f8c2a4c0c8f9f5a9d6b8f184f3e30e0c9e225a34a8c9f0f5b

# JWT token expiry in minutes (default 8 hours)
TOKEN_EXPIRE_MINUTES=480

# Optional bootstrap users created automatically on first startup
PM_ADMIN_USER=admin
PM_ADMIN_PASSWORD=
PM_SMOKE_USER=qa-smoke
PM_SMOKE_PASSWORD=

# Used by the in-app "Frontend E2E Smoke" target for authenticated live checks.
PLAYWRIGHT_REAL_BASE_URL=
PLAYWRIGHT_REAL_USER=qa-smoke
PLAYWRIGHT_REAL_PASSWORD=
PLAYWRIGHT_BROWSERS_PATH=

# ── License ──
# Signing key must match what was used to generate license keys
# (same --secret value passed to tools/generate-license.py)
# REQUIRED — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
LICENSE_SIGN_KEY=changeme-set-a-strong-random-secret-here
# Preferred for new releases: PatchMaster can verify licenses using a public
# key instead of holding the vendor's signing secret.
LICENSE_VERIFY_PUBLIC_KEY=
# Private decryption key used by PatchMaster to read encrypted PM2 licenses
# offline at runtime. This must stay on the PatchMaster side only.
LICENSE_DECRYPT_PRIVATE_KEY=
# Public encryption key shared with the vendor portal/CLI so new PM2 licenses
# can be encrypted for this PatchMaster deployment.
LICENSE_ENCRYPT_PUBLIC_KEY=

# ── CI/CD Secret Encryption ──
# REQUIRED — generate a Fernet key with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PM_SECRET_KEY=changeme-generate-a-fernet-key-here

# ── Monitoring (installed by default on bare-metal; set --without-monitoring to skip) ──
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
PM_MONITORING_PUBLIC_BASE_URL=
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=patchmaster
PROMETHEUS_RETENTION=30d

# ── Docker ──
# Project name prefix for containers
COMPOSE_PROJECT_NAME=patchmaster
