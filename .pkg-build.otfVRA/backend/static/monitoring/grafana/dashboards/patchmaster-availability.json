{
  "title": "PatchMaster - Availability & Patch Pipeline",
  "uid": "pm-availability",
  "schemaVersion": 36,
  "version": 3,
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": "PatchMaster Prometheus",
        "query": "label_values(up{job=\"patchmaster-agents\"}, instance)",
        "refresh": 1,
        "current": {
          "text": "All",
          "value": "All"
        },
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Agents Up",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(up{job=\"patchmaster-agents\",instance=~\"$instance\"} == bool 1) or vector(0)",
          "legendFormat": "Up",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "type": "stat",
      "title": "Agents Down",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(up{job=\"patchmaster-agents\",instance=~\"$instance\"} == bool 0) or vector(0)",
          "legendFormat": "Down",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "type": "stat",
      "title": "Average Latency (ms)",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "(histogram_quantile(0.95, rate(patchmaster_api_request_duration_seconds_bucket[5m])) * 1000) or vector(0)",
          "legendFormat": "Latency",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "type": "stat",
      "title": "API Requests/s",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(patchmaster_api_requests_total[5m])) or vector(0)",
          "legendFormat": "RPS",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "type": "timeseries",
      "title": "Availability over time",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "up{job=\"patchmaster-agents\",instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bool"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "type": "gauge",
      "title": "Current Patch Job Status",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "max(patch_job_status{instance=~\"$instance\"}) or vector(0)",
          "legendFormat": "Current Status",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Idle",
                  "color": "blue"
                },
                "1": {
                  "text": "Running",
                  "color": "yellow"
                },
                "2": {
                  "text": "Success",
                  "color": "green"
                },
                "3": {
                  "text": "Failed",
                  "color": "red"
                }
              }
            }
          ]
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "type": "timeseries",
      "title": "Patch Success / Failures",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum((patch_job_status{instance=~\"$instance\"} == bool 2)) or vector(0)",
          "legendFormat": "Success"
        },
        {
          "expr": "sum((patch_job_status{instance=~\"$instance\"} == bool 3)) or vector(0)",
          "legendFormat": "Failed"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "type": "stat",
      "title": "Linux Agents Up",
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(up{job=\"patchmaster-agents\",instance=~\"$instance\",host_os=\"linux\"} == bool 1) or vector(0)",
          "legendFormat": "Linux Up",
          "instant": true
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "type": "stat",
      "title": "Windows Agents Up",
      "gridPos": {
        "x": 6,
        "y": 10,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(up{job=\"patchmaster-agents\",instance=~\"$instance\",host_os=\"windows\"} == bool 1) or vector(0)",
          "legendFormat": "Windows Up",
          "instant": true
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "type": "stat",
      "title": "Mirror Active Leases",
      "gridPos": {
        "x": 12,
        "y": 10,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "max(patchmaster_mirror_active_leases) or vector(0)",
          "legendFormat": "Active",
          "instant": true
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "type": "stat",
      "title": "Mirror Lock Conflicts (1h)",
      "gridPos": {
        "x": 16,
        "y": 10,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(patchmaster_mirror_sync_lock_conflicts_total[1h])) or vector(0)",
          "legendFormat": "Conflicts",
          "instant": true
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "type": "stat",
      "title": "Stale Leases Cleaned (1h)",
      "gridPos": {
        "x": 20,
        "y": 10,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(patchmaster_mirror_stale_leases_cleaned_total[1h])) or vector(0)",
          "legendFormat": "Cleaned",
          "instant": true
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "type": "table",
      "title": "Latest Patch Times",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 7
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "patch_last_success_timestamp{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value": "Last Patch"
            }
          }
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "type": "table",
      "title": "Alert Matrix: CPU > 80%",
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "max by(instance) (system_cpu_usage_percent{job=\"patchmaster-agents\",instance=~\"$instance\"})",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "type": "table",
      "title": "Alert Matrix: RAM > 80%",
      "gridPos": {
        "x": 12,
        "y": 21,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "max by(instance) (system_memory_usage_percent{job=\"patchmaster-agents\",instance=~\"$instance\"})",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "type": "table",
      "title": "Alert Matrix: Disk I/O (Read+Write B/s)",
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "max by(instance) (system_disk_read_bytes_per_sec{job=\"patchmaster-agents\",instance=~\"$instance\"} + system_disk_write_bytes_per_sec{job=\"patchmaster-agents\",instance=~\"$instance\"})",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10485760 },
              { "color": "red", "value": 20971520 }
            ]
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "type": "stat",
      "title": "Registered Hosts Offline",
      "gridPos": {
        "x": 12,
        "y": 29,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "(patchmaster_hosts_total - patchmaster_hosts_online)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    }
  ],
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "description": "Availability + patch pipeline. Uses agent exporter metrics and backend API metrics."
}
