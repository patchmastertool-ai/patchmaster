{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Host Info",
      "type": "text",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "# Host Details: $instance\n\nDetailed metrics for selected agent."
      }
    },
    {
      "title": "Host OS Kind",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 3
      },
      "targets": [
        {
          "expr": "(max(up{job=\"patchmaster-agents\",instance=\"$instance\",host_os=\"windows\"}) * 1 + max(up{job=\"patchmaster-agents\",instance=\"$instance\",host_os=\"linux\"}) * 2) or vector(0)",
          "legendFormat": "OS Kind",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Unknown",
                  "color": "gray"
                },
                "1": {
                  "text": "Windows",
                  "color": "blue"
                },
                "2": {
                  "text": "Linux",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "gray", "value": null },
              { "color": "blue", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "title": "Host Health Summary",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 3
      },
      "targets": [
        {
          "expr": "up{job=\"patchmaster-agents\",instance=\"$instance\"}",
          "legendFormat": "Health",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Down",
                  "color": "red"
                },
                "1": {
                  "text": "Up",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "title": "Last Scrape Age",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 3
      },
      "targets": [
        {
          "expr": "time() - max(timestamp(up{job=\"patchmaster-agents\",instance=\"$instance\"}))",
          "legendFormat": "Scrape Age",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 60 },
              { "color": "red", "value": 180 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "title": "System Uptime",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 7
      },
      "targets": [
        {
          "expr": "system_uptime_seconds{instance=\"$instance\"}",
          "legendFormat": "Uptime"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "title": "CPU Usage",
      "type": "gauge",
