  "templating": {
    "list": [
      {
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "includeAll": false,
        "label": "Agent",
        "multi": false,
        "name": "instance",
        "options": [],
        "query": "label_values(system_cpu_usage_percent, instance)",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query",
        "datasource": "PatchMaster Prometheus"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "description": "Host-level metrics from PatchMaster agent exporter. If values are empty, verify /metrics on agent:9100 and Prometheus target health.",
