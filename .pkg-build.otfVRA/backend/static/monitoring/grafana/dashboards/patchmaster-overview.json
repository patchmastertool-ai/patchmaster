        "y": 4
      },
      "targets": [
        {
          "expr": "patchmaster_jobs_by_status",
          "legendFormat": "{{status}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {}
      },
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "title": "API Request Rate (5m avg)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "rate(patchmaster_api_requests_total[5m])",
          "legendFormat": "{{method}} {{path}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "title": "API Latency p95 (5m)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(patchmaster_api_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 {{method}} {{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "title": "Agent Patch Job Status",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "expr": "patch_job_status",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Idle"
                },
                "1": {
                  "text": "Running"
                },
                "2": {
                  "text": "Success"
                },
                "3": {
                  "text": "Failed"
                }
              }
            }
          ]
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
    },
    {
      "title": "Hosts Online Over Time",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "targets": [
        {
          "expr": "patchmaster_hosts_total",
          "legendFormat": "Total"
        },
        {
          "expr": "patchmaster_hosts_online",
          "legendFormat": "Online"
        }
      ],
      "fieldConfig": {
        "defaults": {}
      },
      "datasource": {
        "type": "prometheus",
        "uid": "patchmaster-prometheus"
      }
